<full-backup-content>
    <!-- Include Room database files -->
    <include domain="database" path="crochet_inventory_db"/>
    <include domain="database" path="crochet_inventory_db-shm"/>
    <include domain="database" path="crochet_inventory_db-wal"/>

    <!-- Include saved item images -->
    <include domain="file" path="item_images/"/>
</full-backup-content>