<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->

<data-extraction-rules>
    <cloud-backup>
        <!-- Room database -->
        <include domain="database" path="crochet_inventory_db"/>
        <include domain="database" path="crochet_inventory_db-shm"/>
        <include domain="database" path="crochet_inventory_db-wal"/>

        <!-- Saved images -->
        <include domain="file" path="item_images/"/>
    </cloud-backup>

    <device-transfer>
        <include domain="database" path="crochet_inventory_db"/>
        <include domain="database" path="crochet_inventory_db-shm"/>
        <include domain="database" path="crochet_inventory_db-wal"/>
        <include domain="file" path="item_images/"/>
    </device-transfer>
</data-extraction-rules>